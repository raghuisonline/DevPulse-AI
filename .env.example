# JSON array of tenant-scoped Bearer API tokens.
DEVPULSE_API_KEYS=[{"key":"replace-with-at-least-16-characters","tenantId":"tenant_123","tenantName":"Example Workspace"}]

# Remote libSQL database used by the telemetry ingestion pipeline.
LIBSQL_DATABASE_URL=
LIBSQL_AUTH_TOKEN=

# Configure one provider. Groq is preferred when both are present.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct
